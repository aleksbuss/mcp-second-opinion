{
  "name": "mcp-second-opinion",
  "version": "0.2.1",
  "description": "MCP server that asks a panel of LLMs (via OpenRouter) the same question in parallel and returns every answer side by side — with optional synthesis. Get a second opinion before trusting one model.",
  "type": "module",
  "bin": {
    "mcp-second-opinion": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "openrouter",
    "multi-agent",
    "second-opinion",
    "ai"
  ],
  "author": "Aleksejs Buss",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aleksbuss/mcp-second-opinion.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
